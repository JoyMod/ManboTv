# Go 后端开发环境 Dockerfile
FROM golang:1.24-alpine

WORKDIR /app

# 安装 git 和 air (热重载工具)
RUN apk add --no-cache git ca-certificates && \
    go install github.com/cosmtrek/air@latest

# 复制依赖文件
COPY go.mod go.sum ./
RUN go mod download

# 暴露端口
EXPOSE 8080

# 默认命令 (使用 air 热重载)
CMD ["air", "-c", ".air.toml"]
