# ManboTV 环境变量配置
# 复制此文件为 .env 并修改配置

# ============================================
# 管理员账号 (首次启动后请修改密码!)
# ============================================
USERNAME=admin
PASSWORD=your_secure_password_here

# ============================================
# Web 服务端口
# ============================================
WEB_PORT=3000

# ============================================
# Redis 配置 (通常不需要修改)
# ============================================
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================
# Go 后端配置 (可选)
# ============================================
# SERVER_MODE=release
# LOG_LEVEL=info
# AUTH_TOKEN_EXPIRE_HOURS=168
